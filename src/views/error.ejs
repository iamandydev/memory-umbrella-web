<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- Metadata -->
    <title id="pageTitle">@zoolafps · Blog</title>
    <meta name="author" content="@zoolafps">
    <meta name="description" content="Blog personal de @canvasofandy, donde comparto mis pensamientos, experiencias y proyectos relacionados con la tecnología, el desarrollo web y la programación.">
    <meta name="keywords" content="blog, tecnología, desarrollo web, programación, zoolafps, proyectos, experiencias, pensamientos">

    <!-- Stylesheets -->
    <link rel="stylesheet" href="/css/main_stylesheet.css">
    <link rel="stylesheet" href="/css/index_stylesheet.css">
    <!-- Google Fonts -->
     <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
    
<body>
    <!-- Pantalla de carga -->
    <div class="load-screen animated fadeOutDown">
        <!-- From Uiverse.io by david-mohseni -->
        <div class="loader">
            <div class="bar1"></div>
            <div class="bar2"></div>
            <div class="bar3"></div>
            <div class="bar4"></div>
            <div class="bar5"></div>
            <div class="bar6"></div>
            <div class="bar7"></div>
            <div class="bar8"></div>
            <div class="bar9"></div>
            <div class="bar10"></div>
            <div class="bar11"></div>
            <div class="bar12"></div>
        </div>
    </div>
    <!-- Header -->
    <header class="author-info">
        <h2>
            zoolafps
        </h2>
        <span><a href="http://instagram.com/">@zoolafps </a> | Jp</span>
    </header>
    <!-- Tool bar -->
    <nav class="navbar">
        <div>
    
        </div>
        <div id="toggle-dark-mode">
            <!-- From Uiverse.io by JustCode14 -->
            <label class="switch">
                <input checked="true" id="checkbox" type="checkbox" />
                <span class="slider">
                    <div class="star star_1"></div>
                    <div class="star star_2"></div>
                    <div class="star star_3"></div>
                    <svg viewBox="0 0 16 16" class="cloud_1 cloud">
                        <path transform="matrix(.77976 0 0 .78395-299.99-418.63)" fill="#fff"
                            d="m391.84 540.91c-.421-.329-.949-.524-1.523-.524-1.351 0-2.451 1.084-2.485 2.435-1.395.526-2.388 1.88-2.388 3.466 0 1.874 1.385 3.423 3.182 3.667v.034h12.73v-.006c1.775-.104 3.182-1.584 3.182-3.395 0-1.747-1.309-3.186-2.994-3.379.007-.106.011-.214.011-.322 0-2.707-2.271-4.901-5.072-4.901-2.073 0-3.856 1.202-4.643 2.925">
                        </path>
                    </svg>
                </span>
            </label>
        </div>
    </nav>
    <!-- Posts Container -->
    <main id="posts-container" class="animated zoomInDown posts-container">
                <div class="post">
                    <h2><%= message %>...</h2>
                </div>
    </main>

    <!-- Scripts Zone -->
    <script src="/js/animations/effects.js"></script>
</body>
</html>